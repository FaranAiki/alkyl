  %9 = getptr double* %8, 1
  store double %p2, %9
  %10 = load %HP* %5
  %11 = getptr int* %10, 2
  store int %p3, %11
  %12 = load %HP* %5
  %13 = getptr int* %12, 3
  store int %p4, %13
  return void
}

block func int @Attack_attack(%Attack* %p0, %HP %p1) {
entry:
  %0 = onstack %Attack*
  store %Attack* %p0, %0
  %1 = onstack %HP
  store %HP %p1, %1
  %2 = onstack int
  %3 = neq bool %2, 0
  condition %3, then (merge)
then:
  jump merge
merge:
  return int 0
}

