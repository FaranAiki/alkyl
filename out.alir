block func void @Player(%Player* %p0, int %p1, int %p2) {
entry:
  %0 = onstack %Player*
  store %Player* %p0, %0
  %1 = onstack int
  store int %p1, %1
  %2 = onstack int
  store int %p2, %2
  %3 = load int %2
  %4 = load %Player* %0
  %5 = bitcast %Attack* %4
  %6 = getptr int* %5, 0
  store int %3, %6
  %7 = load int %1
  %8 = load %Player* %0
  %9 = bitcast %HP* %8
  %10 = getptr int* %9, 2
  store int %7, %10
  return void
}

block func int @Player_attack(%Player* %p0, %HP %p1) {
