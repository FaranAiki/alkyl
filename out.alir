block func int @main() {
entry:
  %0 = sizeof int type(Player)
  %1 = onheap char* %0
  %2 = bitcast %Player* %1
  %3 = call @Player (%2, 100, 50)
  %4 = onstack %Player*
  store %Player* %2, %4
  %5 = sizeof int type(Enemy)
  %6 = onheap char* %5
  %7 = bitcast %Enemy* %6
  %8 = call @Enemy (%7, @str.0)
  %9 = onstack %Enemy*
  store %Enemy* %7, %9
  %10 = load %Player* %4
  %11 = load %Enemy* %9
  %12 = cast %HP %11
  %13 = call %Player_attack (%10, %12)
  return int 0
}
