promise void* @malloc(long)

block func void @Logger_log(%Logger* %p0, char* %p1) {
entry:
  %0 = onstack %Logger*
  store %Logger* %p0, %0
  %1 = onstack char*
  store char* %p1, %1
  %2 = cast char* @str.0
  %3 = load char* %1
  %4 = call %printf (%2, %3)
  return void
}

block func void @Logger(%Logger* %p0) {
