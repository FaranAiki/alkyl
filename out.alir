block func void @Attack_attack(%Attack* %p0, %HP %p1) {
entry:
  %0 = onstack %Attack*
  store %Attack* %p0, %0
  %1 = onstack %HP
  store %HP %p1, %1
  %2 = getptr int* %1, 3
  %3 = load int %2
  %4 = neq bool %3, 0
  condition %4, then (else)
then:
  %5 = getptr int* %1, 3
  store int 0, %5
  jump merge
else:
  %6 = getptr int* %1, 2
  %7 = load int %6
  %8 = load %Attack* %0
  %9 = getptr int* %8, 0
  %10 = load int %9
  %11 = sub int %7, %10
  %12 = getptr int* %1, 2
  store int %11, %12
  jump merge
merge:
  return void
}

