  %0 = onstack %Player*
  store %Player* %p0, %0
  %1 = onstack %HP
  store %HP %p1, %1
  %2 = onstack int
  %3 = neq bool %2, 0
  condition %3, then (merge)
then:
  jump merge
merge:
  return int 0
