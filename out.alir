; Module: main_module

; Struct Definitions
%struct.Enemy = type { int:damage, int:mult, int:reduction, double:reduction_persen, int:hp, int:shield }
%struct.Player = type { int:damage, int:mult, int:reduction, double:reduction_persen, int:hp, int:shield, string:name }
%struct.Attack = type { int:damage, int:mult }
%struct.HP = type { int:reduction, double:reduction_persen, int:hp, int:shield }
%struct.Defend = type { int:reduction, double:reduction_persen }

; Globals
@str.0 = string "basic"

promise void @Defend_defend(%Defend*, %Attack)

block func void @Defend(%Defend* %p0, int %p1, double %p2) {
entry:
  %0 = onstack %Defend*
  store void %p0, %0
  %1 = load %Defend* %0
  %2 = getptr int* %1, 0
  store int %p1, %2
  %3 = load %Defend* %0
  %4 = getptr double* %3, 1
  store double %p2, %4
  return void
}

promise void @HP_defend(%HP*, %Attack)

