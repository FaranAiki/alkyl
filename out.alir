block func void @Engine_burn(%Engine* %p0, int %p1) {
entry:
  %0 = onstack %Engine*
  store %Engine* %p0, %0
  %1 = onstack int
  store int %p1, %1
  %2 = load %Engine* %0
  %3 = getptr int* %2, 2
  %4 = load int %3
  %5 = load int %1
  %6 = gte bool %4, %5
  condition %6, then (else)
then:
  %7 = load %Engine* %0
  %8 = getptr int* %7, 2
  %9 = load int %8
  %10 = load int %1
  %11 = sub int %9, %10
  %12 = load %Engine* %0
  %13 = getptr int* %12, 2
  store int %11, %13
  %14 = cast char* @str.3
  %15 = load int %1
  %16 = load %Engine* %0
  %17 = getptr int* %16, 2
  %18 = load int %17
  %19 = call %printf (%14, %15, %18)
  jump merge
else:
  %20 = cast char* @str.4
  %21 = load int %1
  %22 = call %printf (%20, %21)
  jump merge
merge:
  return void
}

