; Module: main_module

; Globals
@str.1 = string "%s\n"
@str.0 = string "5"

promise int @printf(char*, ...)

promise void* @malloc(long)

codeblock func double @ama(double %p0) {
entry:
  %0 = onstack double
  store double %p0, %0
  %1 = load double %0
  return double %1
}

codeblock func long @t() {
entry:
