block func int @main() {
entry:
  %0 = sizeof int type(Engine)
  %1 = onheap char* %0
  %2 = bitcast %Engine* %1
  %3 = call @Engine (%2, @str.10, @str.11, 5000, 2000)
  %4 = onstack %Engine*
  store %Engine* %2, %4
  %5 = sizeof int type(LifeSupport)
  %6 = onheap char* %5
  %7 = bitcast %LifeSupport* %6
  %8 = call @LifeSupport (%7, @str.12, @str.13, 98, 4)
  %9 = onstack %LifeSupport*
  store %LifeSupport* %7, %9
  %10 = load %Engine* %4
  %11 = bitcast %Logger* %10
  %12 = cast char* @str.14
  %13 = call %Logger_log (%11, %12)
  %14 = load %Engine* %4
  %15 = call %Engine_report_status (%14)
  %16 = load %LifeSupport* %9
  %17 = call %LifeSupport_report_status (%16)
  %18 = cast char* @str.15
  %19 = call %printf (%18)
  %20 = onheap char* 20
  %21 = bitcast int* %20
  %22 = getptr int* %21, 0
  store int 5, %22
  %23 = getptr int* %21, 1
  store int 4, %23
  %24 = getptr int* %21, 2
  store int 3, %24
  %25 = getptr int* %21, 3
  store int 2, %25
  %26 = getptr int* %21, 4
  store int 1, %26
  %27 = onstack int*
  store int* %21, %27
  %28 = onstack int
  store int 0, %28
  jump while_cond
while_cond:
  %29 = load int %28
  %30 = lt bool %29, 5
  condition %30, while_body (while_end)
while_body:
  %31 = cast char* @str.16
  %32 = load int* %27
  %33 = load int %28
  %34 = getptr int* %32, %33
  %35 = load int %34
  %36 = call %printf (%31, %35)
  %37 = load int %28
  %38 = add int %37, 1
  store int %38, %28
  jump while_cond
while_end:
  %39 = cast char* @str.17
  %40 = call %printf (%39)
  %41 = load %Engine* %4
  %42 = call %Engine_burn (%41, 250)
  %43 = load %Engine* %4
  %44 = bitcast %Logger* %43
  %45 = cast char* @str.18
  %46 = call %Logger_log (%44, %45)
  %47 = cast char* @str.19
  %48 = call %printf (%47)
  %49 = load %LifeSupport* %9
  %50 = call %LifeSupport_daily_cycle (%49)
  %51 = load %LifeSupport* %9
  %52 = getptr int* %51, 2
  %53 = load int %52
  %54 = lt bool %53, 20
  condition %54, then (else)
then:
  %55 = load %LifeSupport* %9
  %56 = bitcast %Logger* %55
  %57 = cast char* @str.20
  %58 = call %Logger_log (%56, %57)
  jump merge
else:
  %59 = load %LifeSupport* %9
  %60 = bitcast %Logger* %59
  %61 = cast char* @str.21
  %62 = call %Logger_log (%60, %61)
  jump merge
merge:
  return int 0
}
