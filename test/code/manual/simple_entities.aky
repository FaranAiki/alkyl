class Defend {
  int reduction = 0;
  double reduction_persen = 0;

  void defend(Attack dmg) {
    
  }
}

class HP has Defend {
  int hp = 0;
  int shield = 0;
}

class Attack {
  int damage = 0;
  int mult = 0;

  void attack(HP hitpoint) {
    if hitpoint.shield != 0 {
       hitpoint.shield = 0;
    } else {
       hitpoint.hp = hitpoint.hp - this.damage;
    }
  }
}

open class Player has Attack, HP {
  string name = "unnamed";
  void init(int hp, int base_dmg) {
    this.damage = base_dmg;
    this.hp = hp;
  }
}

open class Enemy has Attack, HP {
  string name = "enemy";
  void init(string name) {
    this.name = name;
  }
}

int main() {
  let prot = Player(100, 50);
  let enem = Enemy("slime");

  prot.attack(enem);
  return 0;
}
