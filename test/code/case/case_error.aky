extern int printf(char* format, ...);

int main() {
    tainted int x = 10;
    
    clean x {
        printf(c"Clean\n");
    } residue (err) {
        switch err {
            case ErrDivisionByZero:
                printf(c"Div by zero\n");
            case ErrNull:
                printf(c"Null error\n");
        }
    }
    
    return 0;
}
