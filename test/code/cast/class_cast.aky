extern int printf(char*, ...) as cprintf;

// this means the generics only supports those who has OR is single and int
compound[type[single, int] Type] {

class Vector {
  Type x, y;
  as Type {
    cprintf(c"inside as_int: x=%d, y=%d\n", x, y);
    return x * x + y * y;
  }
}

Vector infop[+](Vector a, Vector b) {
  mut Vector[Type] total(a.x + b.x, a.y + b.y);
  return total;
}

}

int main() {
  let gg = Vector[int](1, 3);
  cprintf (c"%s\n", typeof(gg));
  // cprintf(c"%d\n", gg as char); // expect wrong, yet get 16 for somereason 1 * 1 + 2 * 2 = 5
  cprintf(c"%d\n", gg);
  cprintf(c"%d, %d\n", gg.x, gg.y); // print 1, 2
}
