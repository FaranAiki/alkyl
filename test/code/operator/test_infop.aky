class Vector {
    int x;
    int y;
}

Vector infop[+](Vector a, Vector b) {
    mut Vector res;
    res.x = a.x + b.x;
    res.y = a.y + b.y;
    return res;
}

int main() {
    mut Vector a(10, 20);

    mut Vector b(30, 40);

    mut Vector c = a + b;
    if (c.x != 40) return 1;
    if (c.y != 60) return 2;
    return 0;
}
