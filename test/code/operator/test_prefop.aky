class BooleanWrapper {
    bool val;

    as int {
      if val == false then return 0
      else return 1;
    }
}

int prefop[!](BooleanWrapper bw) {
    if (bw.val) return 0;
    return 1;
}

int main() {
    mut BooleanWrapper a;
    a.val = true;

    mut BooleanWrapper b;
    b.val = false;

    if (!a != 0) return 1;
    if (!b != 1) return 2;
    if (b as char* == 1) return 3;
    if (!b as int == 0) return 4;
    return 0;
}
