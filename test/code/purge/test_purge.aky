import "lib/c";

errnum [ErrNull, ErrSomethingElse]

// A tainted function that may purge an error
tainted int divide(int a, int b) {
    if b == 0 {
        purge ErrDivisionByZero;
    }
    return a / b;
}

// A pristine main function
// Still error!
pristine int main() {
    tainted int res_a = divide(10, 2);
    tainted int res_b = divide(10, 0);

    // Using untaint on res_a
    untaint res_a residue err_a {
        if err_a == ErrDivisionByZero {
            // Error handling
            clib.printf("division by zero");
            res_a = 0;
        }
    }
    // res_a is now safe to use as pristine

    clib.printf("%d\n", res_a);

    int t = 1 / 0;

    // Using clean on res_b
    clean res_b as safe_b {
        // safe_b is a pristine copy of res_b and can be safely used
        safe_b = safe_b + 1;
        clib.printf("%d", safe_b);
    } residue err_b {
        clib.printf("%d and %d\n", err_b, ErrDivisionByZero);
        if err_b == ErrDivisionByZero {
            clib.printf("Division by zero!")
        }
    }

    clib.printf("%d\n", res_b
      ?? 2
      ? 3);

    return 0;
}
