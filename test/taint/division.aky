import "lib/c";

double divby?(double a, double b) {
  return a / b;
}

int divby?(int a, int b) {
  if (b == 0) {
    purge ErrDivisionByZero;
  }
  return a / b;
}

int main() {
  // Should fallback to 1.0
  printf("%d\n", divby(2, 0) ? 1);
  pristine let t = divby(2, 0);
  printf ("%s\n", typeof t ? "a");

  return 0;
}
