extern int printf(string format, ...);
extern int scanf(string format, ...);

int main() {
    pristine int user_input;

    printf("Masukkan angka: ");

    // Kita panggil wash untuk memastikan angka valid dan ter-handle
    wash user_input as err {
        int status = scanf("%d", &user_input);
        if (status != 1) {
            printf("Gagal membaca input!\n");
            // lempar error atau fallback
        }
    } else {
        // Di sini user_input sudah pristine!
        printf("Kamu memasukkan angka: %d\n", user_input);

        // Coba kita tambah 10, operasi ini legal karena user_input pristine
        int hasil = user_input + 10;
        printf("Jika ditambah 10, hasilnya: %d\n", hasil);
    }

    return 0;
}
