import "std/vector";
extern int printf(char*, ...);

int test_vector() {
    let v = vector[int]();
    
    // Test push_back
    v.push_back(10);
    v.push_back(20);
    v.push_back(30);

    if (v.size != 3) {
        printf(c"Error: size should be 3\n");
        return 1;
    }

    // Test get
    if (v.get(1) != 20) {
        printf(c"Error: v[1] should be 20\n");
        return 1;
    }

    // Test set
    v.set(1, 99);
    if (v.get(1) != 99) {
        printf(c"Error: v[1] should be 99\n");
        return 1;
    }

    // Test pop_back
    let popped = v.pop_back();
    if (popped != 30) {
        printf(c"Error: popped should be 30\n");
        return 1;
    }
    if (v.size != 2) {
        printf(c"Error: size should be 2 after pop\n");
        return 1;
    }

    // Test insert
    v.insert(1, 44);
    if (v.size != 3 || v.get(1) != 44 || v.get(2) != 99) {
        printf(c"Error: insert failed\n");
        return 1;
    }

    // Test remove
    let removed = v.remove(1);
    if (removed != 44 || v.size != 2 || v.get(1) != 99) {
        printf(c"Error: remove failed\n");
        return 1;
    }

    // Test is_empty and clear
    if (v.is_empty()) {
        printf(c"Error: vector should not be empty\n");
        return 1;
    }
    v.clear();
    if (!v.is_empty()) {
        printf(c"Error: vector should be empty after clear\n");
        return 1;
    }

    printf(c"All tests passed!\n");
    return 0;
}

int main() {
    return test_vector();
}
