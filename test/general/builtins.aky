extern int printf(string fmt, ...);

int main() {
    int x = 10;
    
    // Testing sizeof
    printf("sizeof(int): %d\n", sizeof(int));
    printf("sizeof(x): %d\n", sizeof(x));
    
    // Testing typeof
    string type_int = typeof(int);
    string type_x = typeof(x);
    printf("typeof(int): %s\n", type_int);
    printf("typeof(x): %s\n", type_x);
    
    // Testing alignof
    printf("alignof(int): %d\n", alignof(int));
    printf("alignof(x): %d\n", alignof(x));
    
    // Testing defer
    printf("Start of scope\n");
    defer {
        printf("Deferred execution at end of scope!\n");
    }
    printf("End of scope\n");
    
    return 0;
}
