class Vector {
    int x;
    int y;
}

Vector infop[+](Vector a, Vector b) {
    mut Vector res;
    res.x = a.x + b.x;
    res.y = a.y + b.y;
    return res;
}

int main() {
    mut Vector a;
    a.x = 10;
    a.y = 20;

    mut Vector b;
    b.x = 30;
    b.y = 40;

    mut Vector c = a + b;
    if (c.x != 40) return 1;
    if (c.y != 60) return 2;
    return 0;
}
