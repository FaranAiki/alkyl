class StringObj {
    int len;
}

int infop[+](StringObj a, StringObj b) {
    return a.len + b.len;
}

int infop[==](StringObj a, StringObj b) {
    if (a.len == b.len) return 1;
    return 0;
}

int main() {
    mut StringObj a;
    a.len = 5;
    
    mut StringObj b;
    b.len = 10;
    
    mut StringObj c;
    c.len = 5;

    if ((a + b) != 15) return 1;
    if ((a == b) != 0) return 2;
    if ((a == c) != 1) return 3;
    
    return 0;
}
