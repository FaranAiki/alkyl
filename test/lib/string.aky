extern int printf(char* fmt, ...);
extern void* malloc(unsigned int size);

import "lib/std/string.aky"

int main() {
    string* s = malloc(sizeof(string));
    s.init(c"Hello World");

    int length = s.length();
    printf(c"Length: %d\n", length ? 0);

    s.tolower();
    char* data_lower = s.data;
    printf(c"Lower: %s\n", data_lower ? "");

    s.toupper();
    char* data_upper = s.data;
    untaint data_upper {}
    printf(c"Upper: %s\n", data_upper ? "");

    return 0;
}
