extern int printf(char* fmt, ...);
extern void* malloc(unsigned int size);
extern void free(void* ptr);

import "lib/std/vector.aky"

int main() {
    let v = vector[int]();
    v.init();
    
    v.push_back(10);
    v.push_back(20);
    v.push_back(30);
    
    printf(c"Size: %d\n", v.size);
    printf(c"Capacity: %d\n", v.capacity);
    
    printf(c"Popped: %d\n", v.pop_back());
    printf(c"Popped: %d\n", v.pop_back());
    printf(c"Popped: %d\n", v.pop_back());
    
    printf(c"Size after pop: %d\n", v.size);
    
    return 0;
}
