// sebenarnya ini harusnya trait tapi biarkan namanya masih prototipe, lagi pula ini showcase
extern int printf(char*, ...);
extern int scanf(char*, ...);

import "std/string";

trait Kecepatan {
  int kecepatan = 3;
}

trait Waktu {
  int waktu;
}

// has-a, compo bukan inheritance
open class Jarak has Waktu, Kecepatan {
  void out() {
    printf("%d\n", this.waktu * this.kecepatan);
  }
}

int main() {
  int t = 0;
  int v = 0;
  printf("Masukkan waktu (t): ");
  scanf("%d", &t);
  printf("Masukkan kecepatan (v): ");
  scanf("%d", &v);

  Jarak s;
  s.kecepatan = v;
  s.waktu = t;

  printf("Jarak = ");
  s.out();
  return 0;
}
